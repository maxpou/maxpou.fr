---
import { Picture } from 'astro:assets'
import type { CollectionEntry } from 'astro:content'

type Props = {
  recipe: CollectionEntry<'recipes'>
}

const { recipe } = Astro.props
---

<a
  title={recipe.data.title}
  href={`/recipes/${recipe.data.slug}/`}
  class="ease flex flex-col rounded-lg bg-white transition duration-300 dark:bg-gray-500
    hover:translate-y-0.5 shadow-md hover:shadow-xl group"
>
  {
    recipe.data.cover && (
      <Picture
        src={recipe.data.cover}
        width={420}
        height={224}
        formats={['webp', 'avif', 'jpeg']}
        alt={`Cover image for ${recipe.data.title}`}
        loading="lazy"
        decoding="async"
        class="h-56 w-full rounded-b-none rounded-t-lg object-cover transition"
      />
    )
  }
  <div class="p-4">
    <span
      class="from-blue-100 to-blue-100 text-dark dark:bg-none font-semibold text-xl text-gray-700 dark:text-gray-100
        bg-linear-to-r bg-size-[0px_10px] bg-bottom-left bg-no-repeat transition-[background-size] duration-500 group-hover:bg-size-[100%_10px]"
    >
      {recipe.data.title}
    </span>
  </div>
</a>
